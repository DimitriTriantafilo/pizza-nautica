---
import { Image, type ImageMetadata } from "astro:assets";

interface Props {
  name: string;
  description: string;
  image: ImageMetadata;
}

const { name, description, image } = Astro.props;
---

<article class="section-card overflow-hidden">
  <Image src={image} alt={name} class="h-48 w-full object-cover" />
  <div class="p-4">
    <h3 class="mb-2 text-xl font-semibold">{name}</h3>
    <p class="text-sm text-white/80">{description}</p>
  </div>
</article>
