---
import type { Lang } from "../data/menu";
import {
  normalizeWebMenuResponse,
  WEB_MENU_URL_ORIGIN,
} from "../lib/webmenu";
import { useTranslations } from "../i18n/utils";
import { Image } from "astro:assets";
import heroBg from "../assets/images/hero/morrones.jpg";
import velero from "../assets/images/hero/velero.png";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

let buildData: unknown = [];
try {
  const res = await fetch(WEB_MENU_URL_ORIGIN, {
    headers: { Accept: "application/json" },
  });
  if (res.ok) buildData = await res.json();
} catch {
  /* build-time fetch failed; client will retry */
}

const buildCategories = normalizeWebMenuResponse(buildData);
---

<!-- Hero: static, images optimised at build time -->
<section
  class="menu-page-hero relative z-20 overflow-hidden md:min-h-[34rem] md:py-32"
>
  <Image
    src={heroBg}
    alt=""
    aria-hidden="true"
    class="block w-full h-auto md:absolute md:w-[100vw] md:h-auto md:left-1/2 md:top-1/2 md:-translate-x-1/2 md:-translate-y-1/2"
    widths={[640, 1280, 1920]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
  <div class="absolute inset-0 bg-black/60"></div>
  <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-[var(--charcoal)]/90 via-[var(--terracotta)]/10 to-transparent"></div>

  <div class="absolute inset-0 z-10 flex flex-col items-center justify-center px-4 text-center">
    <p class="w-full max-w-5xl text-xs font-semibold uppercase tracking-[0.3em] text-[var(--nautica-yellow)]">
      {lang === "es" ? "Carta de la casa" : "House menu"}
    </p>
    <h1 class="mt-4 w-full max-w-6xl font-[var(--font-display)] text-[clamp(1.875rem,5vw,3.75rem)] font-bold leading-tight text-balance text-[var(--warm-ivory)] md:text-6xl">
      {t("menu.title")}
    </h1>
    <p class="mt-6 w-full max-w-5xl text-pretty text-base text-[var(--warm-ivory)]/80 sm:text-lg">
      {t("menu.subtitle")}
    </p>
    <p class="mt-2 w-full max-w-5xl text-pretty text-sm text-[var(--warm-ivory)]/55">
      {t("menu.note")}
    </p>
  </div>
</section>

<!-- Build-time data embedded as JSON so the client can render instantly -->
<script
  id="menu-build-data"
  type="application/json"
  set:html={JSON.stringify(buildData)}
/>

<!-- Client-rendered menu: shows build-time data first, then upgrades with a live fetch -->
<div
  id="menu-app"
  data-lang={lang}
  data-velero-src={velero.src}
  data-nav-label={t("menu.rubroNav")}
>
  <!-- Loading skeleton (only visible if build-time data was empty) -->
  {
    buildCategories.length === 0 && (
      <section class="relative z-20 bg-[var(--cream-1)] py-16">
        <div class="container-shell-wide py-0 text-center">
          <div class="animate-pulse space-y-4">
            <div class="mx-auto h-6 w-48 rounded bg-[var(--ink-maroon)]/15" />
            <div class="mx-auto h-4 w-64 rounded bg-[var(--ink-maroon)]/10" />
            <div class="mx-auto h-4 w-56 rounded bg-[var(--ink-maroon)]/10" />
          </div>
        </div>
      </section>
    )
  }
</div>

<script>
  import type { Lang } from "../data/menu";
  import { normalizeWebMenuResponse, getWebMenuURL } from "../lib/webmenu";
  import { renderMenuHTML } from "../lib/menu-renderer";

  const MESSAGES: Record<Lang, { error: string; empty: string }> = {
    es: {
      error: "No pudimos cargar el menú en este momento. Probá más tarde.",
      empty: "El menú no tiene ítems disponibles.",
    },
    en: {
      error: "We could not load the menu right now. Please try again later.",
      empty: "The menu has no items available.",
    },
  };

  function initMenuRubroNav() {
    const nav = document.querySelector("[data-menu-rubro-nav]");
    if (!nav || !("IntersectionObserver" in window)) return;

    const links = [
      ...nav.querySelectorAll('a[href^="#"]'),
    ] as HTMLAnchorElement[];
    if (links.length === 0) return;

    const sections = links
      .map((a) => {
        const id = a.getAttribute("href")?.slice(1);
        return id ? document.getElementById(id) : null;
      })
      .filter((el): el is HTMLElement => el !== null);

    function setActive(id: string) {
      links.forEach((link) => {
        const href = link.getAttribute("href")?.slice(1);
        if (href === id) {
          link.setAttribute("aria-current", "location");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
        if (visible.length === 0) return;
        setActive(visible[0].target.id);
      },
      {
        root: null,
        rootMargin: "-18% 0px -52% 0px",
        threshold: [0, 0.06, 0.12, 0.2],
      },
    );

    sections.forEach((s) => observer.observe(s));

    const hash = window.location.hash.slice(1);
    if (hash && document.getElementById(hash)) {
      setActive(hash);
    }
  }

  function render(
    root: HTMLElement,
    data: unknown,
    lang: Lang,
    veleroSrc: string,
    navLabel: string,
  ): boolean {
    const msg = MESSAGES[lang];
    const categories = normalizeWebMenuResponse(data);

    if (categories.length === 0) {
      root.innerHTML = `
        <section class="relative z-20 bg-[var(--cream-1)] py-16">
          <div class="container-shell-wide py-0 text-center">
            <p class="text-[var(--charcoal)]/70">${msg.empty}</p>
          </div>
        </section>`;
      return false;
    }

    root.innerHTML = renderMenuHTML(categories, lang, veleroSrc, navLabel);
    initMenuRubroNav();
    return true;
  }

  async function initMenu() {
    const root = document.getElementById("menu-app");
    if (!root) return;

    const lang = (root.dataset.lang || "es") as Lang;
    const veleroSrc = root.dataset.veleroSrc || "";
    const navLabel = root.dataset.navLabel || "";
    const msg = MESSAGES[lang];

    const buildEl = document.getElementById("menu-build-data");
    let hasBuildData = false;

    if (buildEl?.textContent) {
      try {
        const buildJSON = JSON.parse(buildEl.textContent);
        hasBuildData = render(root, buildJSON, lang, veleroSrc, navLabel);
      } catch {
        /* malformed build data – will fetch live */
      }
    }

    try {
      const res = await fetch(getWebMenuURL(), {
        headers: { Accept: "application/json" },
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      render(root, await res.json(), lang, veleroSrc, navLabel);
    } catch {
      if (!hasBuildData) {
        root.innerHTML = `
          <section class="relative z-20 bg-[var(--cream-1)] py-16">
            <div class="container-shell-wide py-0 text-center">
              <p class="text-[var(--nautica-red)]" role="alert">${msg.error}</p>
            </div>
          </section>`;
      }
    }
  }

  initMenu();
  document.addEventListener("astro:after-swap", initMenu);
</script>
