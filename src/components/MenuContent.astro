---
import { menuCategories, type Lang } from "../data/menu";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative z-20 bg-[var(--charcoal)] py-24 md:py-32">
  <div class="container-shell px-6 text-center">
    <p
      class="text-xs font-semibold uppercase tracking-[0.3em]
      text-[var(--nautica-yellow)]"
    >
      {lang === "es" ? "Carta de la casa" : "House menu"}
    </p>
    <h1
      class="mt-4 font-[var(--font-display)] text-4xl font-bold leading-tight
      text-[var(--warm-ivory)] md:text-6xl"
    >
      {t("menu.title")}
    </h1>
    <p class="mx-auto mt-6 max-w-3xl text-lg text-[var(--warm-ivory)]/75">
      {t("menu.subtitle")}
    </p>
    <p class="mx-auto mt-2 max-w-3xl text-sm text-[var(--warm-ivory)]/55">
      {t("menu.note")}
    </p>
  </div>
</section>

{
  menuCategories.map((category, categoryIndex) => (
    <section
      class:list={[
        "relative z-20 py-16 md:py-20",
        categoryIndex % 2 === 0
          ? "bg-[var(--cream-1)]"
          : "bg-[var(--charcoal)]",
      ]}
    >
      <div class="container-shell px-6">
        <h2
          class:list={[
            "text-center font-[var(--font-display)] text-4xl font-bold",
            "md:text-5xl",
            categoryIndex % 2 === 0
              ? "text-[var(--charcoal)]"
              : "text-[var(--warm-ivory)]",
          ]}
        >
          {category.name[lang]}
        </h2>

        <div class="mx-auto mt-6 flex w-full max-w-xl items-center gap-3">
          <span
            class:list={[
              "h-px flex-1",
              categoryIndex % 2 === 0
                ? "bg-[var(--charcoal)]/20"
                : "bg-[var(--warm-ivory)]/30",
            ]}
          ></span>
          <span
            class:list={[
              "h-2 w-2 rounded-full",
              categoryIndex % 2 === 0
                ? "bg-[var(--nautica-red)]"
                : "bg-[var(--nautica-yellow)]",
            ]}
          ></span>
          <span
            class:list={[
              "h-px flex-1",
              categoryIndex % 2 === 0
                ? "bg-[var(--charcoal)]/20"
                : "bg-[var(--warm-ivory)]/30",
            ]}
          ></span>
        </div>

        <div class="mt-12 grid gap-10 lg:grid-cols-2">
          {category.subCategories.map((subCategory) => (
            <article>
              <h3
                class:list={[
                  "text-sm font-semibold uppercase tracking-[0.25em]",
                  categoryIndex % 2 === 0
                    ? "text-[var(--nautica-red)]"
                    : "text-[var(--nautica-yellow)]",
                ]}
              >
                {subCategory.name[lang]}
              </h3>

              <ul class="mt-5 divide-y" role="list">
                {subCategory.dishes[lang].map((dish) => (
                  <li
                    class:list={[
                      "py-3 text-base",
                      "md:text-lg",
                      categoryIndex % 2 === 0
                        ? "border-[var(--charcoal)]/15 text-[var(--charcoal)]"
                        : "border-[var(--warm-ivory)]/20 text-[var(--warm-ivory)]",
                    ]}
                  >
                    {dish.name}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))
}
