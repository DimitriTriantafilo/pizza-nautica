---
import { Image } from "astro:assets";
import historia1 from "../assets/images/hero/historia 1.jpg";
import historia2 from "../assets/images/hero/historia 2.jpg";
import historia3 from "../assets/images/hero/historia 3.jpg";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
---

<section class="relative z-20 bg-[var(--cream-1)] pb-24 pt-6">
  <div class="container-shell px-4 md:px-4">
    <div class="mx-auto grid max-w-[1200px] grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <article class="overflow-hidden rounded-[12px] shadow-nautica-lg">
        <Image
          src={historia1}
          alt={lang === "es" ? "Escena de cocina de Pizza Náutica" : "Kitchen scene at Pizza Nautica"}
          class="h-[500px] w-full object-cover grayscale transition duration-700 ease-out hover:grayscale-0"
          widths={[640, 960, 1280]}
          sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
          loading="lazy"
        />
      </article>

      <article class="overflow-hidden rounded-[12px] shadow-nautica-lg">
        <Image
          src={historia2}
          alt={lang === "es" ? "Preparación artesanal de masa" : "Artisan dough preparation"}
          class="h-[500px] w-full object-cover grayscale transition duration-700 ease-out hover:grayscale-0"
          widths={[640, 960, 1280]}
          sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
          loading="lazy"
        />
      </article>

      <article class="overflow-hidden rounded-[12px] shadow-nautica-lg">
        <Image
          src={historia3}
          alt={lang === "es" ? "Ambientación interior de Pizza Náutica" : "Interior ambience at Pizza Nautica"}
          class="h-[500px] w-full object-cover grayscale transition duration-700 ease-out hover:grayscale-0"
          widths={[640, 960, 1280]}
          sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
          loading="lazy"
        />
      </article>
    </div>

    <div class="mt-10 flex justify-center">
      <a href={`/${lang}/historia`} class="btn-primary whitespace-nowrap">{lang === "es" ? "Conocé nuestra historia" : "View our story"}</a>
    </div>
  </div>
</section>
