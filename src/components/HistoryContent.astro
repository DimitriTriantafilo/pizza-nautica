---
import { Image } from "astro:assets";
import { useTranslations } from "../i18n/utils";
import destacada3 from "../assets/images/hero/destacada 3.jpg";
import destacada4 from "../assets/images/hero/destacada 4.jpg";
import destacada1 from "../assets/images/hero/destacada1.jpg";
import destacada2 from "../assets/images/hero/destacada2.jpg";
import historia1 from "../assets/images/hero/historia 1.jpg";
import historia2 from "../assets/images/hero/historia 2.jpg";
import historia3 from "../assets/images/hero/historia 3.jpg";
import morrones from "../assets/images/hero/morrones.jpg";
import historiaFrente from "../assets/images/hero/historia frente.jpg";
import historiaFoto1 from "../assets/images/hero/historia1.jpg";
import historia4 from "../assets/images/hero/historia4.jpg";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const isEs = lang === "es";

const quoteEs = `\u201CLa pizza es mucho m\u00E1s que masa y salsa. Es el fuego, la espera, el aroma que llena la sala y la sonrisa de quien la recibe.\u201D`;
const quoteEn = `\u201CPizza is much more than dough and sauce. It\u2019s the fire, the wait, the aroma that fills the room and the smile of whoever receives it.\u201D`;

const carouselImages = [destacada1, destacada2, destacada3, destacada4, morrones];
const spacesImages = [historia1, historia2, historia3];
---

<!-- Section 1: Hero — img replaces bg-fixed to avoid scroll repaint jank -->
<section class="relative z-20 overflow-hidden py-24 md:py-32">
  <Image
    src={historiaFrente}
    alt={t("site.name")}
    class="absolute inset-0 h-full w-full object-cover"
    widths={[640, 1280, 1920]}
    sizes="100vw"
    loading="eager"
  />
  <div class="absolute inset-0 bg-black/50"></div>
  <div class="container-shell relative z-10 px-6 text-center" data-animate-section>
    <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--nautica-yellow)]"
       data-anim="subtitle" style="--delay:0s">
      {isEs ? "Desde 1995" : "Since 1995"}
    </p>
    <h1 class="mt-4 font-[var(--font-display)] text-4xl font-bold leading-tight text-[var(--warm-ivory)] md:text-6xl"
        data-anim="title" style="--delay:0.1s">
      {t("history.title")}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-[var(--warm-ivory)]/70"
       data-anim="body" style="--delay:0.2s">
      {t("history.subtitle")}
    </p>
  </div>
</section>

<!-- Section 2: Origin story -->
<section class="relative z-20 bg-[var(--cream-1)] py-20">
  <div class="container-shell px-6">
    <div class="grid items-center gap-12 md:grid-cols-2" data-animate-section>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--nautica-red)]"
           data-anim="subtitle" style="--delay:0s">
          {isEs ? "El comienzo" : "The beginning"}
        </p>
        <h2 class="mt-3 font-[var(--font-display)] text-3xl font-bold leading-snug text-[var(--charcoal)] md:text-4xl"
            data-anim="title" style="--delay:0.1s">
          {isEs ? "Una tradici\u00F3n que naci\u00F3 junto al r\u00EDo" : "A tradition born by the river"}
        </h2>
        <p class="mt-6 leading-relaxed text-[var(--charcoal)]/75"
           data-anim="body" style="--delay:0.2s">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.
        </p>
        <p class="mt-4 leading-relaxed text-[var(--charcoal)]/75"
           data-anim="body" style="--delay:0.28s">
          Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident.
        </p>
      </div>
      <div class="overflow-hidden rounded-2xl" data-anim="image" style="--delay:0.3s">
        <Image
          src={historiaFoto1}
          alt="Pizza Nautica interior"
          class="h-[450px] w-full object-cover"
          widths={[600, 900]}
          sizes="(min-width: 768px) 50vw, 100vw"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

<!-- Section 3: Accent quote -->
<section class="relative z-20 overflow-hidden py-16 md:py-20">
  <Image
    src={historia4}
    alt="Pizza Nautica ambience"
    class="absolute inset-0 h-full w-full object-cover"
    widths={[640, 1280]}
    sizes="100vw"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-black/60"></div>
  <div class="container-shell relative z-10 px-6 text-center" data-animate-section>
    <p class="mx-auto max-w-3xl font-[var(--font-display)] text-2xl leading-relaxed text-[var(--warm-ivory)] md:text-3xl"
       data-anim="quote" style="--delay:0.1s">
      {isEs ? quoteEs : quoteEn}
    </p>
  </div>
</section>

<!-- Section 4: Three-image grid -->
<section class="relative z-20 bg-[var(--cream-1)] py-20">
  <div class="container-shell px-6">
    <div data-animate-section>
      <p class="text-center text-xs font-semibold uppercase tracking-[0.3em] text-[var(--nautica-red)]"
         data-anim="subtitle" style="--delay:0s">
        {isEs ? "Cada rinc\u00F3n, una historia" : "Every corner, a story"}
      </p>
      <h2 class="mt-3 text-center font-[var(--font-display)] text-3xl font-bold text-[var(--charcoal)] md:text-4xl"
          data-anim="title" style="--delay:0.1s">
        {isEs ? "Nuestros espacios" : "Our spaces"}
      </h2>
    </div>

    <!-- Mobile carousel -->
    <div
      id="history-spaces-carousel"
      class="mt-12 overflow-hidden rounded-xl sm:hidden"
      aria-roledescription="carousel"
      aria-label={isEs ? "Galería de espacios" : "Spaces gallery"}
      data-animate-section
    >
      <div id="history-spaces-track" class="flex transition-transform duration-700 ease-in-out">
        {spacesImages.map((item, i) => (
          <div class="w-full shrink-0 overflow-hidden rounded-xl" role="group" aria-roledescription="slide" aria-label={`${i + 1} / ${spacesImages.length}`}>
            <img src={item.src} alt={`Pizza Nautica interior ${i + 1}`} class="h-[420px] w-full object-cover grayscale" loading="lazy" />
          </div>
        ))}
      </div>
      <div class="mt-4 flex items-center justify-center gap-2">
        {spacesImages.map((_, i) => (
          <button
            class="spaces-dot h-2.5 w-2.5 rounded-full border border-[var(--charcoal)]/30 bg-transparent transition-all duration-300"
            data-index={i}
            aria-label={`${isEs ? "Ir a imagen" : "Go to image"} ${i + 1}`}
          />
        ))}
      </div>
    </div>

    <!-- Desktop grid -->
    <div class="mt-12 hidden grid-cols-1 gap-4 sm:grid sm:grid-cols-3" data-animate-section>
      <div class="overflow-hidden rounded-xl" data-anim="image" style="--delay:0s">
        <img src={historia1.src} alt="Pizza Nautica interior 1" class="h-[420px] w-full object-cover grayscale transition duration-700 ease-out hover:grayscale-0" loading="lazy" />
      </div>
      <div class="overflow-hidden rounded-xl" data-anim="image" style="--delay:0.1s">
        <img src={historia2.src} alt="Pizza Nautica interior 2" class="h-[420px] w-full object-cover grayscale transition duration-700 ease-out hover:grayscale-0" loading="lazy" />
      </div>
      <div class="overflow-hidden rounded-xl" data-anim="image" style="--delay:0.2s">
        <img src={historia3.src} alt="Pizza Nautica interior 3" class="h-[420px] w-full object-cover grayscale transition duration-700 ease-out hover:grayscale-0" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- Section 5: Evolution -->
<section class="relative z-20 bg-[var(--charcoal)] py-20">
  <div class="container-shell px-6">
    <div class="grid items-center gap-12 md:grid-cols-2" data-animate-section>
      <div class="overflow-hidden rounded-2xl md:order-1" data-anim="image" style="--delay:0.3s">
        <Image
          src={destacada4}
          alt="Pizza Nautica tradicion"
          class="h-[450px] w-full object-cover"
          widths={[600, 900]}
          sizes="(min-width: 768px) 50vw, 100vw"
          loading="lazy"
        />
      </div>
      <div class="md:order-2">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-[var(--nautica-yellow)]"
           data-anim="subtitle" style="--delay:0s">
          {isEs ? "Evoluci\u00F3n" : "Evolution"}
        </p>
        <h2 class="mt-3 font-[var(--font-display)] text-3xl font-bold leading-snug text-[var(--warm-ivory)] md:text-4xl"
            data-anim="title" style="--delay:0.1s">
          {isEs ? "Hablar de N\u00E1utica es hablar de San Fernando" : "To speak of Nautica is to speak of San Fernando"}
        </h2>
        <p class="mt-6 leading-relaxed text-[var(--warm-ivory)]/70"
           data-anim="body" style="--delay:0.2s">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Praesent commodo cursus magna, vel scelerisque nisl consectetur et. Donec sed odio dui. Maecenas faucibus mollis interdum.
        </p>
        <p class="mt-4 leading-relaxed text-[var(--warm-ivory)]/70"
           data-anim="body" style="--delay:0.28s">
          Nullam quis risus eget urna mollis ornare vel eu leo. Cras mattis consectetur purus sit amet fermentum. Integer posuere erat a ante venenatis dapibus posuere velit aliquet.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Section 6: Carousel -->
<section class="relative z-20 bg-[var(--cream-1)] py-20">
  <div class="container-shell px-6">
    <div data-animate-section>
      <p class="text-center text-xs font-semibold uppercase tracking-[0.3em] text-[var(--nautica-red)]"
         data-anim="subtitle" style="--delay:0s">
        {isEs ? "Galer\u00EDa" : "Gallery"}
      </p>
      <h2 class="mt-3 text-center font-[var(--font-display)] text-3xl font-bold text-[var(--charcoal)] md:text-4xl"
          data-anim="title" style="--delay:0.1s">
        {isEs ? "El sabor en im\u00E1genes" : "Flavor in images"}
      </h2>
    </div>

    <div id="history-carousel" class="mt-12 overflow-hidden rounded-2xl" aria-roledescription="carousel" aria-label={isEs ? "Galer\u00EDa de im\u00E1genes" : "Image gallery"} data-animate-section>
      <div id="carousel-track" class="flex transition-transform duration-700 ease-in-out" data-anim="image" style="--delay:0.15s">
        {carouselImages.map((item, i) => (
          <div class="w-full shrink-0" role="group" aria-roledescription="slide" aria-label={`${i + 1} / ${carouselImages.length}`}>
            <img
              src={item.src}
              alt={`Pizza Nautica ${i + 1}`}
              class={`h-[350px] w-full md:h-[500px] ${i === 0 ? "object-cover object-top" : "object-cover"}`}
              loading="lazy"
            />
          </div>
        ))}
      </div>

      <div class="mt-6 flex items-center justify-center gap-2">
        {carouselImages.map((_, i) => (
          <button
            class="carousel-dot h-2.5 w-2.5 rounded-full border border-[var(--charcoal)]/30 bg-transparent transition-all duration-300"
            data-index={i}
            aria-label={`${isEs ? "Ir a imagen" : "Go to image"} ${i + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* Initial hidden states — only opacity + transform, no reflow */
  [data-anim] {
    opacity: 0;
    will-change: transform, opacity;
  }

  [data-anim="subtitle"] { transform: translateY(-5px); }
  [data-anim="title"]    { transform: translateY(12px); }
  [data-anim="body"]     { transform: translateY(10px); }
  [data-anim="quote"]    { transform: translateY(10px); }
  [data-anim="image"]    { transform: scale(1.05); }

  /* Revealed state — parent section gets .is-visible */
  [data-animate-section].is-visible [data-anim] {
    opacity: 1;
    transform: none;
    transition:
      opacity 0.6s cubic-bezier(0.165, 0.84, 0.44, 1) var(--delay, 0s),
      transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1) var(--delay, 0s);
  }

  /* Respect reduced-motion preference */
  @media (prefers-reduced-motion: reduce) {
    [data-anim] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  // ── Scroll-triggered animations ──────────────────────────────────────────
  function initAnimations() {
    const sections = document.querySelectorAll<HTMLElement>("[data-animate-section]");
    if (!sections.length || !("IntersectionObserver" in window)) {
      // Fallback: reveal all immediately
      sections.forEach((s) => s.classList.add("is-visible"));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08 },
    );

    sections.forEach((s) => observer.observe(s));
  }

  // ── Spaces carousel ───────────────────────────────────────────────────────
  function initSpacesCarousel() {
    const track = document.getElementById("history-spaces-track") as HTMLElement | null;
    const dots = document.querySelectorAll(".spaces-dot");
    if (!track || dots.length === 0) return;

    const total = dots.length;
    let current = 0;
    let interval: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track!.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        const active = i === current;
        d.classList.toggle("bg-[var(--nautica-red)]", active);
        d.classList.toggle("border-[var(--nautica-red)]", active);
        d.classList.toggle("bg-transparent", !active);
      });
    }

    function autoplay() {
      interval = setInterval(() => goTo(current + 1), 4500);
    }

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        clearInterval(interval);
        goTo(Number((dot as HTMLElement).dataset.index));
        autoplay();
      });
    });

    goTo(0);
    autoplay();
  }

  // ── Main carousel ─────────────────────────────────────────────────────────
  function initCarousel() {
    const track = document.getElementById("carousel-track") as HTMLElement | null;
    const dots = document.querySelectorAll(".carousel-dot");
    if (!track || dots.length === 0) return;

    const total = dots.length;
    let current = 0;
    let interval: ReturnType<typeof setInterval>;

    function goTo(index: number) {
      current = ((index % total) + total) % total;
      track!.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        const active = i === current;
        d.classList.toggle("bg-[var(--nautica-red)]", active);
        d.classList.toggle("border-[var(--nautica-red)]", active);
        d.classList.toggle("bg-transparent", !active);
      });
    }

    function autoplay() {
      interval = setInterval(() => goTo(current + 1), 5000);
    }

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        clearInterval(interval);
        goTo(Number((dot as HTMLElement).dataset.index));
        autoplay();
      });
    });

    goTo(0);
    autoplay();
  }

  initAnimations();
  initSpacesCarousel();
  initCarousel();
  document.addEventListener("astro:after-swap", initAnimations);
  document.addEventListener("astro:after-swap", initSpacesCarousel);
  document.addEventListener("astro:after-swap", initCarousel);
</script>
