---
import { Image } from "astro:assets";
import { useTranslations } from "../i18n/utils";
import heroImage from "../assets/images/hero/FRENTE APAISADO P NAUTICA.jpg";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const siteName = lang === "es" ? "Pizza Náutica" : "Pizza Nautica";
const letters = siteName.split("");
// Last letter animation ends at: (letters.length - 1) * 0.03 + 0.6s
const subtitleDelay = ((letters.length - 1) * 0.03 + 0.65).toFixed(2);
---

<section class="hero-section relative min-h-screen overflow-hidden">
  <Image
    src={heroImage}
    alt={t("site.name")}
    class="absolute inset-0 h-full w-full object-cover object-center"
    widths={[640, 1280, 1920]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    priority
  />

  <!-- Warm-toned glass overlay for legibility -->
  <div class="absolute inset-0 bg-[var(--glass-overlay)]"></div>

  <!-- Cinematic base gradient: charcoal fade at bottom with warm terracotta mid-tone -->
  <div
    class="absolute inset-x-0 bottom-0 h-3/4 bg-gradient-to-t
      from-[var(--charcoal)]/85 via-[var(--terracotta)]/15 to-transparent"
  ></div>

  <!-- Hero content: centered -->
  <div
    class="relative z-10 flex min-h-screen flex-col items-center justify-center
      px-4 text-center"
  >
    <h1
      aria-label={siteName}
      class="font-[var(--font-display)] font-bold leading-none
        text-[clamp(2.5rem,8vw,5rem)] text-[var(--warm-ivory)]
        tracking-wide drop-shadow-[0_2px_8px_rgba(0,0,0,0.55)]"
    >
      {letters.map((letter, i) => (
        <span
          class="hero-letter inline-block"
          style={`animation-delay:${(i * 0.03).toFixed(2)}s`}
          aria-hidden="true"
        >
          {letter === " " ? "\u00A0" : letter}
        </span>
      ))}
    </h1>

    <p
      class="hero-subtitle mt-6 font-[var(--font-body)] font-semibold uppercase
        tracking-[0.28em] text-[var(--warm-ivory)]/80
        text-xs sm:text-sm md:text-base
        drop-shadow-[0_1px_4px_rgba(0,0,0,0.5)]"
      style={`animation-delay:${subtitleDelay}s`}
    >
      {t("site.lema")}
    </p>
  </div>
</section>

<style>
  @keyframes letterReveal {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes blockFadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-letter {
    opacity: 0;
    will-change: transform, opacity;
    animation: letterReveal 0.6s cubic-bezier(0.215, 0.61, 0.355, 1) forwards;
  }

  .hero-subtitle {
    opacity: 0;
    will-change: transform, opacity;
    animation: blockFadeIn 0.5s cubic-bezier(0.215, 0.61, 0.355, 1) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-letter,
    .hero-subtitle {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
