---
import { Image } from "astro:assets";
import featuredDish from "../assets/images/hero/destacada1.jpg";
import sideImageMain from "../assets/images/hero/destacada 4.jpg";
import sideImageSecond from "../assets/images/hero/destacada2.jpg";
import sideImageThird from "../assets/images/hero/morrones.jpg";

interface Props {
  lang: "es" | "en";
}

const { lang } = Astro.props;
---

<section class="relative z-20 bg-[var(--cream-1)] pb-16 pt-24">
  <h2
    id="featured-heading"
    class="mx-auto max-w-[min(100%,34rem)] px-4 text-center text-[clamp(1.25rem,4.2vw,2.25rem)] font-[var(--font-display)] font-bold leading-snug text-[var(--charcoal)] text-balance sm:px-6 md:max-w-[40rem] md:leading-tight transform translate-y-4 scale-95 opacity-0 transition duration-900 ease-out"
  >
    {lang === "es" ? (
      <>
        <span class="text-[var(--nautica-red)]">30 años</span> en el corazón de San Fernando
      </>
    ) : (
      <>
        <span class="text-[var(--nautica-red)]">30 years</span> in the heart of San Fernando
      </>
    )}
  </h2>

  <div class="mt-16 w-full">
    <Image
      src={featuredDish}
      alt={lang === "es" ? "Pizza promocional destacada del menú" : "Featured promotional pizza from the menu"}
      class="h-[430px] w-full object-cover mt-35"
      widths={[800, 1280, 1920]}
      sizes="100vw"
      loading="lazy"
    />
  </div>

  <div
    class="mx-auto mt-16 flex max-w-[1200px] flex-col gap-10 px-4 sm:px-6 md:flex-row md:items-center"
  >
    <div class="min-w-0 md:w-1/2">
      <p class="font-[var(--font-body)] text-base text-[var(--charcoal)] text-pretty md:text-lg">
        {lang === "es"
          ? "Fuego prendido masa lista y todos los ingredientes de primera calidad para llevar a tu mesa una pizza de primer nivel."
          : "A glimpse into our kitchen: dough, fire, and conversations by the oven."}
      </p>
      <div class="mt-6">
        <a href={`/${lang}/menu`} class="btn-primary whitespace-nowrap">
          {lang === "es" ? "ir al menú" : "Go to menu"}
        </a>
      </div>
    </div>

    <div class="min-w-0 md:w-1/2">
      <div class="relative mx-auto h-[280px] w-full max-w-[420px] sm:h-[320px]">
        <div class="absolute left-0 top-4 z-10 h-[200px] w-[53%] max-w-[220px] rotate-4 overflow-hidden shadow-nautica-lg">
          <Image
            src={sideImageSecond}
            alt={lang === "es" ? "Ingredientes listos para la pizza" : "Pizza ingredients ready"}
            class="h-full w-full object-cover"
            widths={[320, 480]}
            sizes="220px"
            loading="lazy"
          />
        </div>
        <div
          class="absolute right-0 top-0 z-8 h-[200px] w-[53%] max-w-[220px] -rotate-4 overflow-hidden shadow-nautica-lg"
        >
           <Image
            src={sideImageThird}
            alt={lang === "es" ? "Detalle de cocina de Pizza Náutica" : "Pizza Nautica kitchen detail"}
            class="h-full w-full object-cover"
            widths={[320, 480]}
            sizes="220px"
            loading="lazy"
          />
        </div>
      
      </div>
    </div>
  </div>
</section>

<script>
  const heading = document.getElementById("featured-heading");

  if (heading && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            heading.classList.remove("translate-y-4", "scale-95", "opacity-0");
            heading.classList.add("translate-y-0", "scale-100", "opacity-100");
            observer.disconnect();
          }
        });
      },
      { threshold: 0.5 }
    );

    observer.observe(heading);
  } else if (heading) {
    heading.classList.remove("translate-y-4", "scale-95", "opacity-0");
    heading.classList.add("translate-y-0", "scale-100", "opacity-100");
  }
</script>
