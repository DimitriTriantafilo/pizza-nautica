---
import "@fontsource-variable/playfair-display";
import "@fontsource-variable/montserrat";
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingButtons from "../components/FloatingButtons.astro";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: "es" | "en";
  title: string;
  description: string;
  canonicalPath: string;
  ogImage?: string;
  isHome?: boolean;
}

const { lang, title, description, canonicalPath, ogImage, isHome = false } = Astro.props;
const t = useTranslations(lang);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  name: t("site.name"),
  address: {
    "@type": "PostalAddress",
    streetAddress: "Doctor San Gines 801",
    addressLocality: "San Fernando",
    addressRegion: "Buenos Aires",
    addressCountry: "AR",
  },
  servesCuisine: "Pizza",
  url: new URL(canonicalPath, Astro.site ?? "https://pizzanautica.com").toString(),
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogImage={ogImage}
      lang={lang}
    />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <Navbar lang={lang} currentPath={Astro.url.pathname} />
    <main class:list={["min-h-screen", isHome ? "" : "pt-16"]}>
      <slot />
    </main>
    <Footer lang={lang} />
    <FloatingButtons lang={lang} />
  </body>
</html>
